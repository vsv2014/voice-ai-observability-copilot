# ── Copy to .env and fill in only what you need. Everything works with NO keys. ──

# Server
PORT=3001

# GHL integration mode: "mock" (default, no creds) or "live"
GHL_MODE=mock

# ── HighLevel (only needed when GHL_MODE=live) ──
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_ACCESS_TOKEN=
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28

# ── LLM analysis (optional). If none set, a deterministic rule-based analyzer is used. ──
# Choose ONE free provider. See README for how to get a free key.
LLM_PROVIDER=deterministic   # deterministic | gemini | groq

# Google Gemini (free tier): https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
